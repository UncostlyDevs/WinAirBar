<Window x:Class="FloatingTaskbarMenu.Windows.TaskbarMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FloatingTaskbarMenu.Controls"
        Title="Taskbar Menu"
        Width="320"
        SizeToContent="Height"
        MaxHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Opacity="{Binding MenuOpacity}"
        Loaded="OnLoaded"
        Deactivated="OnDeactivated">

    <Border Background="{DynamicResource MenuBackgroundBrush}"
            BorderBrush="{DynamicResource MenuBorderBrush}"
            BorderThickness="{DynamicResource AirBarBorderThickness}"
            CornerRadius="{DynamicResource AirBarCornerRadius}">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="6" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderBrush}"
                    CornerRadius="{DynamicResource AirBarHeaderCornerRadius}"
                    Padding="16,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8"
                               Cursor="SizeAll"
                               MouseLeftButtonDown="OnDragHandleMouseLeftButtonDown">
                        <Button x:Name="QuickSettingsButton"
                                DockPanel.Dock="Right"
                                Width="28"
                                Height="26"
                                Padding="0"
                             ToolTip="WinAirBar settings"
                                Click="OnQuickSettingsClick"
                                Style="{StaticResource AuxiliaryButtonStyle}">
                            <controls:ThemeIconView Kind="Settings"
                                                    FallbackGlyph="&#xE713;"
                                                    IconSize="15"
                                                    GlyphFontSize="15"
                                                    Foreground="{DynamicResource HeaderTextBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                        </Button>
                        <TextBlock Text="Windows"
                                   FontSize="{DynamicResource AirBarBaseFontSize}"
                                   FontWeight="SemiBold"
                                   FontFamily="{DynamicResource AirBarDisplayFontFamily}"
                                   Foreground="{DynamicResource HeaderTextBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBox x:Name="SearchBox"
                             Text="Search windows..."
                             FontSize="{DynamicResource AirBarBaseFontSize}"
                             Padding="8,6"
                             Background="{DynamicResource HoverBrush}"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             FontFamily="{DynamicResource AirBarFontFamily}"
                             GotFocus="OnSearchBoxGotFocus"
                             LostFocus="OnSearchBoxLostFocus"
                             TextChanged="OnSearchBoxTextChanged"/>
                </StackPanel>
            </Border>

            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Fill="{DynamicResource BorderBrush}"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="6,4">
                <StackPanel>
                    <controls:WindowListView x:Name="WindowListView"
                                             Visibility="{Binding ShowWindowList, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <controls:SystemTrayView x:Name="SystemTrayView"
                                             Visibility="{Binding ShowSystemTray, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Background="{DynamicResource FooterBrush}"
                    CornerRadius="{DynamicResource AirBarFooterCornerRadius}"
                    Padding="8,6"
                    Visibility="{Binding ShowAuxiliaryControls, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:AuxiliaryControls x:Name="AuxiliaryControls"/>
            </Border>
        </Grid>
    </Border>
</Window>
