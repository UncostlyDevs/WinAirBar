<Window x:Class="FloatingTaskbarMenu.Windows.BackupConflictWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Backup Import Conflicts"
        Width="760"
        Height="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        Loaded="OnLoaded">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="Choose Import Conflict Actions"
                       FontSize="18"
                       FontWeight="SemiBold"
                       FontFamily="{DynamicResource AirBarDisplayFontFamily}"/>
            <TextBlock Text="WinAirBar will create a pre-import backup first. Workspaces and profiles default to Import As Copy; settings-style data defaults to Keep Local."
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Width="92"
                    Click="OnCancelClick"
                    Style="{StaticResource MenuItemButtonStyle}"/>
            <Button Content="Use Choices"
                    Width="110"
                    Margin="8,0,0,0"
                    Click="OnOkClick"
                    Style="{StaticResource MenuItemButtonStyle}"/>
        </StackPanel>

        <DataGrid x:Name="ConflictGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Section" Binding="{Binding Section}" IsReadOnly="True" Width="130"/>
                <DataGridTextColumn Header="Item" Binding="{Binding Name}" IsReadOnly="True" Width="180"/>
                <DataGridTextColumn Header="Target" Binding="{Binding TargetPath}" IsReadOnly="True" Width="*"/>
                <DataGridComboBoxColumn x:Name="ChoiceColumn"
                                        Header="Choice"
                                        SelectedItemBinding="{Binding Choice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
