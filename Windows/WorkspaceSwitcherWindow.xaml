<Window x:Class="FloatingTaskbarMenu.Windows.WorkspaceSwitcherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workspace Switcher"
        Width="780"
        Height="280"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        Loaded="OnLoaded"
        KeyDown="OnKeyDown">
    <Border Margin="12"
            Padding="14"
            Background="{DynamicResource MenuBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource AirBarCornerRadius}">
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock Text="Workspace Switcher"
                           FontSize="18"
                           FontWeight="SemiBold"
                           FontFamily="{DynamicResource AirBarDisplayFontFamily}"
                           DockPanel.Dock="Left"/>
                <Button Content="Esc"
                        Width="48"
                        HorizontalAlignment="Right"
                        Click="OnCloseClick"
                        DockPanel.Dock="Right"
                        Style="{StaticResource MenuItemButtonStyle}"/>
            </DockPanel>

            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Content="Preview"
                        Padding="12,5"
                        Click="OnPreviewClick"
                        Style="{StaticResource MenuItemButtonStyle}"/>
                <Button Content="Restore"
                        Margin="8,0,0,0"
                        Padding="12,5"
                        Click="OnRestoreClick"
                        Style="{StaticResource MenuItemButtonStyle}"/>
                <Button Content="Missing Only"
                        Margin="8,0,0,0"
                        Padding="12,5"
                        Click="OnMissingOnlyClick"
                        Style="{StaticResource MenuItemButtonStyle}"/>
            </StackPanel>

            <ListBox x:Name="WorkspaceCards"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     SelectionMode="Single">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="210"
                                Height="126"
                                Margin="0,0,10,0"
                                Padding="12"
                                Background="{DynamicResource HoverBrush}"
                                BorderBrush="{Binding BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="{DynamicResource AirBarInnerCornerRadius}">
                            <StackPanel>
                                <DockPanel>
                                    <Border Width="12"
                                            Height="12"
                                            CornerRadius="6"
                                            Background="{Binding ColorBrush}"
                                            DockPanel.Dock="Left"
                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                                <TextBlock Text="{Binding Info}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding Health}"
                                           Margin="0,6,0,0"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
