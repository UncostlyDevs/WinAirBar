<Window x:Class="FloatingTaskbarMenu.Windows.WorkspaceControlCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workspace Control Center"
        Width="1040"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MenuBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        Loaded="OnLoaded">
    <Window.Resources>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource AirBarFontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource AirBarBaseFontSize}"/>
        </Style>
        <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource ThemedComboBoxStyle}"/>
        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabChrome"
                                Margin="0,0,4,0"
                                Padding="{TemplateBinding Padding}"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource AirBarInnerCornerRadius}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{DynamicResource ItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabChrome" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.32*" MinWidth="280" MaxWidth="340"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="12"
                Background="{DynamicResource MenuBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource AirBarCornerRadius}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Workspaces"
                               FontSize="18"
                               FontWeight="SemiBold"
                               FontFamily="{DynamicResource AirBarDisplayFontFamily}"/>
                    <TextBlock Text="Save, see, and bring back your layouts."
                               Margin="0,4,0,10"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"/>
                    <UniformGrid Rows="1" Columns="2" Margin="0,0,0,8">
                        <Button Content="Refresh"
                                Margin="0,0,4,0"
                                Click="OnRefreshClick"
                                Style="{StaticResource MenuItemButtonStyle}"/>
                        <Button Content="Switcher"
                                Margin="4,0,0,0"
                                Click="OnOpenSwitcherClick"
                                Style="{StaticResource MenuItemButtonStyle}"/>
                    </UniformGrid>
                </StackPanel>

                <ListBox x:Name="WorkspaceList"
                         SelectionChanged="OnWorkspaceSelectionChanged"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnWorkspaceCardRightClick"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    HorizontalAlignment="Stretch"
                                    Background="{DynamicResource HoverBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource AirBarInnerCornerRadius}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="64"
                                            Height="42"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource AirBarInnerCornerRadius}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="UniformToFill"/>
                                            <TextBlock Text="{Binding ThumbnailFallback}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="2"
                                                ClipToBounds="True">
                                        <DockPanel>
                                            <Border Width="10"
                                                    Height="10"
                                                    CornerRadius="5"
                                                    Background="{Binding ColorBrush}"
                                                    Margin="0,0,8,0"
                                                    DockPanel.Dock="Left"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Name}"
                                                       MinWidth="0"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Info}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   MinWidth="0"/>
                                        <TextBlock Text="{Binding Health}"
                                                   Margin="0,3,0,0"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   MinWidth="0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Padding="12"
                Background="{DynamicResource MenuBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource AirBarCornerRadius}">
            <DockPanel>
                <TextBlock x:Name="StatusText"
                           DockPanel.Dock="Bottom"
                           Margin="0,10,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>

                <TabControl x:Name="WorkspaceTabs"
                            Background="Transparent">
                    <TabItem Header="Details">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock x:Name="OverviewTitle"
                                           Text="Select a workspace"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           FontFamily="{DynamicResource AirBarDisplayFontFamily}"/>
                                <TextBlock x:Name="OverviewSummary"
                                           Margin="0,4,0,12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>

                                <ItemsControl x:Name="DetailsScreenStrip"
                                              Margin="0,0,0,14">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="180"
                                                    Margin="0,0,10,10"
                                                    Padding="8"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="{DynamicResource AirBarInnerCornerRadius}">
                                                <StackPanel>
                                                    <Border Height="96"
                                                            Background="{DynamicResource HoverBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{DynamicResource AirBarInnerCornerRadius}"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="{Binding Image}"
                                                                   Stretch="UniformToFill"/>
                                                            <TextBlock Text="{Binding EmptyText}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       TextAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}"
                                                               Margin="0,6,0,0"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Padding="12"
                                        Margin="0,0,0,14"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource AirBarInnerCornerRadius}">
                                    <StackPanel>
                                        <TextBlock Text="Capture"
                                                   FontWeight="SemiBold"
                                                   FontSize="15"/>
                                        <TextBlock Text="Save what is open now."
                                                   Margin="0,2,0,10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Workspace name" Margin="0,0,0,4"/>
                                                <TextBox x:Name="CaptureNameBox"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Snapshot name" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SnapshotNameBox"/>
                                            </StackPanel>
                                        </Grid>
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Content="Save New"
                                                    Margin="0,0,8,8"
                                                    Padding="12,6"
                                                    Click="OnCaptureWorkspaceClick"
                                                    Style="{StaticResource PrimaryMenuItemButtonStyle}"/>
                                            <Button Content="Update Selected"
                                                    Margin="0,0,8,8"
                                                    Padding="12,6"
                                                    Click="OnUpdateWorkspaceClick"
                                                    Style="{StaticResource MenuItemButtonStyle}"/>
                                            <Button Content="Save Snapshot"
                                                    Margin="0,0,8,8"
                                                    Padding="12,6"
                                                    Click="OnSaveSnapshotClick"
                                                    Style="{StaticResource MenuItemButtonStyle}"/>
                                            <Button Content="Reload Gallery"
                                                    Margin="0,0,0,8"
                                                    Padding="12,6"
                                                    Click="OnRefreshScreensClick"
                                                    Style="{StaticResource MenuItemButtonStyle}"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Notes" Margin="0,0,0,4"/>
                                        <TextBox x:Name="NotesBox"
                                                 Height="96"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>
                                        <TextBlock Text="Icon" Margin="0,10,0,4"/>
                                        <TextBox x:Name="IconKeyBox"/>
                                        <TextBlock Text="Color" Margin="0,10,0,4"/>
                                        <TextBox x:Name="ColorBox"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Restore style" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="MetadataRestoreModeCombo"/>
                                        <TextBlock Text="Cleanup style" Margin="0,10,0,4"/>
                                        <ComboBox x:Name="MetadataCleanupCombo"/>
                                        <Button Content="Save Details"
                                                Margin="0,14,0,0"
                                                HorizontalAlignment="Left"
                                                Padding="12,6"
                                                Click="OnSaveMetadataClick"
                                                Style="{StaticResource MenuItemButtonStyle}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Auto actions"
                                           Margin="0,14,0,4"/>
                                <TextBlock Text="One per line: Kind|Name|Target|Arguments"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox x:Name="AutoActionsBox"
                                         Height="110"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Screens">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Screen Gallery"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           FontFamily="{DynamicResource AirBarDisplayFontFamily}"/>
                                <TextBlock Text="A saved visual memory for this workspace."
                                           Margin="0,4,0,12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <ItemsControl x:Name="ScreenGalleryItems">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="300"
                                                    Margin="0,0,12,12"
                                                    Padding="10"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="{DynamicResource AirBarInnerCornerRadius}">
                                                <StackPanel>
                                                    <Border Height="170"
                                                            Background="{DynamicResource HoverBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{DynamicResource AirBarInnerCornerRadius}">
                                                        <Grid ClipToBounds="True">
                                                            <Image Source="{Binding Image}"
                                                                   Stretch="UniformToFill"/>
                                                            <TextBlock Text="{Binding EmptyText}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       TextAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}"
                                                               Margin="0,8,0,0"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Details}"
                                                               Margin="0,2,0,0"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding WindowList}"
                                                               Margin="0,6,0,0"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Restore">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="170"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="How"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <ComboBox x:Name="RestoreModeCombo"
                                          Width="160"/>
                                <Button Content="Show Plan"
                                        Margin="8,0,0,0"
                                        Padding="12,5"
                                        Click="OnPreviewClick"
                                        Style="{StaticResource MenuItemButtonStyle}"/>
                                <Button Content="Restore"
                                        Margin="8,0,0,0"
                                        Padding="12,5"
                                        Click="OnRestorePlanClick"
                                        Style="{StaticResource MenuItemButtonStyle}"/>
                            </StackPanel>

                            <DataGrid x:Name="PlanGrid"
                                      Grid.Row="1"
                                      Margin="0,10,0,10"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="120"/>
                                    <DataGridTextColumn Header="Window" Binding="{Binding DisplayName}" Width="*"/>
                                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="130"/>
                                    <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" Width="110"/>
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="260"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="2"
                                       Text="Extra windows"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

                            <DataGrid x:Name="ExtraGrid"
                                      Grid.Row="3"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Window" Binding="{Binding Title}" Width="*"/>
                                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="120"/>
                                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="200"/>
                                    <DataGridComboBoxColumn x:Name="ExtraActionColumn"
                                                            Header="Action"
                                                            SelectedItemBinding="{Binding Action, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="History">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Version"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <ComboBox x:Name="VersionCombo"
                                          Width="240"/>
                                <Button Content="Restore Version"
                                        Margin="8,0,0,0"
                                        Padding="12,5"
                                        Click="OnRestoreVersionClick"
                                        Style="{StaticResource MenuItemButtonStyle}"/>
                            </StackPanel>
                            <DataGrid x:Name="TimelineGrid"
                                      Grid.Row="1"
                                      Margin="0,10,0,0"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="When" Binding="{Binding CreatedAt}" Width="150"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding EventType}" Width="120"/>
                                    <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*"/>
                                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="220"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Rules">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Window Rules"
                                           FontWeight="SemiBold"
                                           FontSize="16"/>
                                <TextBlock Text="Tell WinAirBar what to ignore, keep, or move."
                                           Margin="0,4,0,8"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <Grid Margin="0,8,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="App process"/>
                                        <TextBox x:Name="RuleProcessBox"/>
                                        <CheckBox x:Name="RuleExcludeCheck"
                                                  Content="Do not capture"
                                                  Margin="0,8,0,0"/>
                                        <CheckBox x:Name="RuleNeverCleanupCheck"
                                                  Content="Never clean up"
                                                  Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Cleanup"/>
                                        <ComboBox x:Name="RuleCleanupCombo"/>
                                        <TextBlock Text="Restore" Margin="0,8,0,0"/>
                                        <ComboBox x:Name="RuleRestoreModeCombo"/>
                                        <TextBlock Text="Position" Margin="0,8,0,0"/>
                                        <ComboBox x:Name="RulePositionCombo"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Content="Save"
                                                    Padding="12,5"
                                                    Click="OnSaveRuleClick"
                                                    Style="{StaticResource MenuItemButtonStyle}"/>
                                            <Button Content="Delete"
                                                    Margin="8,0,0,0"
                                                    Padding="12,5"
                                                    Click="OnDeleteRuleClick"
                                                    Style="{StaticResource MenuItemButtonStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <DataGrid x:Name="RulesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          Height="170">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="150"/>
                                        <DataGridCheckBoxColumn Header="Exclude" Binding="{Binding ExcludeFromCapture}" Width="80"/>
                                        <DataGridCheckBoxColumn Header="Never Cleanup" Binding="{Binding NeverCleanup}" Width="110"/>
                                        <DataGridTextColumn Header="Cleanup" Binding="{Binding DefaultCleanupAction}" Width="110"/>
                                        <DataGridTextColumn Header="Restore" Binding="{Binding DefaultRestoreMode}" Width="100"/>
                                        <DataGridTextColumn Header="Position" Binding="{Binding DefaultPosition}" Width="110"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Separator Margin="0,14"/>
                                <TextBlock Text="Window Groups"
                                           FontWeight="SemiBold"
                                           FontSize="16"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                                    <TextBox x:Name="GroupNameBox"
                                             Width="220"
                                             Text="Quick Group"/>
                                    <Button Content="Save Group"
                                            Margin="8,0,0,0"
                                            Padding="12,5"
                                            Click="OnCaptureGroupClick"
                                            Style="{StaticResource MenuItemButtonStyle}"/>
                                    <Button Content="Open Group"
                                            Margin="8,0,0,0"
                                            Padding="12,5"
                                            Click="OnLaunchGroupClick"
                                            Style="{StaticResource MenuItemButtonStyle}"/>
                                </StackPanel>
                                <ListBox x:Name="GroupsList" Height="100"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Ideas &amp; Tags">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="180"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid x:Name="SuggestionsGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Apps" Binding="{Binding Apps}" Width="*"/>
                                    <DataGridTextColumn Header="Seen" Binding="{Binding SeenCount}" Width="70"/>
                                    <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        Margin="0,8,0,12">
                                <Button Content="Save Workspace"
                                        Padding="12,5"
                                        Click="OnSaveSuggestionClick"
                                        Style="{StaticResource MenuItemButtonStyle}"/>
                                <Button Content="Dismiss"
                                        Margin="8,0,0,0"
                                        Padding="12,5"
                                        Click="OnDismissSuggestionClick"
                                        Style="{StaticResource MenuItemButtonStyle}"/>
                                <Button Content="Never Suggest"
                                        Margin="8,0,0,0"
                                        Padding="12,5"
                                        Click="OnNeverSuggestClick"
                                        Style="{StaticResource MenuItemButtonStyle}"/>
                            </StackPanel>

                            <DataGrid x:Name="LauncherGrid"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="App" Binding="{Binding Name}" IsReadOnly="True" Width="180"/>
                                    <DataGridTextColumn Header="Path" Binding="{Binding ExecutablePath}" IsReadOnly="True" Width="*"/>
                                    <DataGridTextColumn Header="Tags (comma separated)" Binding="{Binding TagsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button Grid.Row="3"
                                    Content="Save Launcher Tags"
                                    Margin="0,10,0,0"
                                    Padding="12,5"
                                    HorizontalAlignment="Left"
                                    Click="OnSaveLauncherTagsClick"
                                    Style="{StaticResource MenuItemButtonStyle}"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
